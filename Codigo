function loadImage(btn, ~)
    fig = ancestor(btn,'figure');
    data = guidata(fig);

    [file,path] = uigetfile({'*.jpg;*.png;*.bmp;*.tif','Imágenes'});
    if isequal(file,0), return; end

    img = imread(fullfile(path,file));
    data.img = img;

    % Convertir a escala de grises para el análisis espectral
    if size(img,3) == 3
        data.imgGray = double(rgb2gray(img));
    else
        data.imgGray = double(img);
    end
    data.result = [];

    axes(data.axOrig); imshow(img); 
    title('x(t): Imagen Original','FontSize',8);

    % Mostrar espectro de entrada inmediatamente
    mostrarEspectro(data.imgGray, data.axEspX, '|X(j\omega)| - Espectro Entrada', data.Fs_x);

    axes(data.axResult); cla; axis off;
    axes(data.axEspY);   cla; axis off;
    axes(data.axH);      cla; axis off;
    axes(data.axDiff);   cla; axis off;

    guidata(fig,data);
end

% =========================================================================
% PROCESAMIENTO EN DOMINIO DE FRECUENCIA (CORE)
% =========================================================================
function procesarEnFrecuencia(btn, ~)
    fig = ancestor(btn,'figure');
    data = guidata(fig);

    if isempty(data.imgGray)
        errordlg('Primero cargue una imagen.','Sin señal de entrada');
        return;
    end

    set(btn,'Enable','off','String','Procesando FFT...');
    drawnow;

    fc1   = get(data.sliderFc1,'Value');
    fc2   = get(data.sliderFc2,'Value');
    n_ord = round(get(data.sliderOrden,'Value'));
    modo  = get(data.popupFiltro,'Value');
    forma = get(data.popupForma,'Value');

    [rows, cols] = size(data.imgGray);

    % ---- 1. FFT 2D de la señal de entrada ----
    X = fft2(data.imgGray);
    X_shift = fftshift(X);   % centrar componente DC

    % ---- 2. Construir máscara H(jω) en 2D ----
    % Crear grilla de frecuencias normalizadas (0..0.5 ciclos/px)
    [u, v] = meshgrid( linspace(-0.5, 0.5, cols), linspace(-0.5, 0.5, rows) );
    D = sqrt(u.^2 + v.^2);   % distancia radial al DC

    H_mask = construirFiltro(D, fc1, fc2, n_ord, modo, forma);

    % ---- 3. Aplicar filtro: Y(jω) = H(jω) · X(jω) ----
    Y_shift = X_shift .* H_mask;
    Y = ifftshift(Y_shift);

    % ---- 4. IFFT 2D para obtener y(t) ----
    y = real(ifft2(Y));

    % Saturar a [0, 255]
    y = y - min(y(:));
    y = y / max(y(:)) * 255;
    data.result = uint8(y);

    % ---- 5. Diferencia (efecto extraído) ----
    diff_img = double(data.imgGray) - y;
    diff_img = diff_img - min(diff_img(:));
    diff_img = diff_img / max(diff_img(:)) * 255;

    % ---- 6. Visualizar resultados ----
    % H(jω)
    axes(data.axH);
    imagesc(linspace(-0.5,0.5,cols), linspace(-0.5,0.5,rows), H_mask);
    colormap(data.axH, jet); colorbar(data.axH);
    xlabel('u (ciclos/px)','FontSize',7); ylabel('v (ciclos/px)','FontSize',7);
    title('H(j\omega) - Respuesta en Frecuencia','FontSize',8);
    xline(data.axH, fc1,'w--','LineWidth',1.2);
    if ismember(modo,[3,4]), xline(data.axH, fc2,'w:','LineWidth',1.2); end
    axis(data.axH,'xy');

    % y(t)
    axes(data.axResult); imshow(data.result);
    title('y(t): Imagen Procesada','FontSize',8);

    % |Y(jω)|
    mostrarEspectro(y, data.axEspY, '|Y(j\omega)| - Espectro Salida', data.Fs_x);

    % Diferencia
    axes(data.axDiff); imagesc(diff_img); colormap(data.axDiff,gray); axis image off;
    title('x(t) - y(t): Efecto extraído','FontSize',8);

    set(btn,'Enable','on','String','2.  Procesar en Frecuencia');
    guidata(fig,data);
end

% =========================================================================
% ANÁLISIS FOURIER COMPLETO — ventana independiente
% =========================================================================
function verAnalisisFourier(btn, ~)
    fig = ancestor(btn,'figure');
    data = guidata(fig);

    if isempty(data.imgGray)
        errordlg('Cargue una imagen primero.','Error');
        return;
    end

    [rows, cols] = size(data.imgGray);
    X     = fft2(data.imgGray);
    Xsh   = fftshift(X);
    mag   = log(1 + abs(Xsh));
    fase  = angle(Xsh);

    % Frecuencias en ciclos/pixel
    fu = linspace(-0.5, 0.5, cols);
    fv = linspace(-0.5, 0.5, rows);

    % Perfil 1D horizontal (fila central)
    fila_c  = round(rows/2);
    perfil  = abs(Xsh(fila_c,:));
    perfil_db = 20*log10(perfil + 1e-6);

    % Frecuencia máxima y mínima significativas (−40 dB)
    umbral  = max(perfil_db) - 40;
    idx_sig = find(perfil_db > umbral);
    fmax    = fu(idx_sig(end));
    fmin    = fu(idx_sig(1));

    figF = figure('Name','Análisis de Fourier 2D','NumberTitle','off',...
        'Position',[100 60 1100 700],'Color',[1 1 1]);

    % -- Imagen original --
    subplot(3,3,1);
    imshow(uint8(data.imgGray)); title('x(t): Imagen original','FontWeight','bold');

    % -- Magnitud espectral 2D --
    subplot(3,3,2);
    imagesc(fu, fv, mag); colormap(gca,hot); colorbar;
    xlabel('u (ciclos/px)'); ylabel('v (ciclos/px)');
    title('|X(j\omega)| — Magnitud (log)','FontWeight','bold');
    axis xy;

    % -- Fase espectral 2D --
    subplot(3,3,3);
    imagesc(fu, fv, fase); colormap(gca,hsv); colorbar;
    xlabel('u (ciclos/px)'); ylabel('v (ciclos/px)');
    title('\angle X(j\omega) — Fase','FontWeight','bold');
    axis xy;

    % -- Perfil 1D de magnitud --
    subplot(3,3,4:5);
    plot(fu, perfil_db,'b','LineWidth',1.5); grid on;
    xlabel('Frecuencia u (ciclos/px)','FontSize',9);
    ylabel('Magnitud (dB)','FontSize',9);
    title('Perfil espectral horizontal 1D de x(t)','FontWeight','bold');
    xline(fmax,'r--','LineWidth',1.2,'Label',sprintf('f_{max}=%.3f',fmax),'LabelVerticalAlignment','bottom');
    xline(fmin,'g--','LineWidth',1.2,'Label',sprintf('f_{min}=%.3f',fmin),'LabelVerticalAlignment','bottom');
    xline(0,'k:','LineWidth',1,'Label','DC');
    legend({'|X(j\omega)| dB','f_{max} (-40dB)','f_{min} (-40dB)','DC'},'Location','northeast');

    if ~isempty(data.result)
        y     = double(data.result);
        Ysh   = fftshift(fft2(y));
        mag_y = log(1 + abs(Ysh));
        perfil_y = abs(Ysh(fila_c,:));
        perfil_y_db = 20*log10(perfil_y + 1e-6);

        % -- Imagen resultado --
        subplot(3,3,7);
        imshow(data.result); title('y(t): Imagen de salida','FontWeight','bold');

        % -- Magnitud espectral Y --
        subplot(3,3,8);
        imagesc(fu, fv, mag_y); colormap(gca,hot); colorbar;
        xlabel('u (ciclos/px)'); ylabel('v (ciclos/px)');
        title('|Y(j\omega)| — Magnitud (log)','FontWeight','bold');
        axis xy;

        % -- Comparación perfiles 1D --
        subplot(3,3,6);
        plot(fu, perfil_db,'b','LineWidth',1.5); hold on;
        plot(fu, perfil_y_db,'r--','LineWidth',1.5);
        grid on; legend({'|X(j\omega)|','|Y(j\omega)|'},'Location','best');
        xlabel('Frecuencia (ciclos/px)'); ylabel('dB');
        title('Comparación espectral 1D','FontWeight','bold');

        % -- Diferencia en frecuencia --
        diff_mag = log(1 + abs(Xsh - Ysh));
        subplot(3,3,9);
        imagesc(fu, fv, diff_mag); colormap(gca,jet); colorbar;
        xlabel('u (ciclos/px)'); ylabel('v (ciclos/px)');
        title('|X-Y|(j\omega) — Frecuencias modificadas','FontWeight','bold');
        axis xy;
    end

    sgtitle('Análisis de Señales en el Dominio del Tiempo y Frecuencia',...
        'FontSize',13,'FontWeight','bold','Color',[0.1 0.25 0.55]);
end

% =========================================================================
% RESPUESTA AL IMPULSO h(t) Y RESPUESTA EN FRECUENCIA H(jω)
% =========================================================================
function verRespuestaSistema(btn, ~)
    fig = ancestor(btn,'figure');
    data = guidata(fig);

    fc1   = get(data.sliderFc1,'Value');
    fc2   = get(data.sliderFc2,'Value');
    n_ord = round(get(data.sliderOrden,'Value'));
    modo  = get(data.popupFiltro,'Value');
    forma = get(data.popupForma,'Value');

    tipos = {'Pasa-Bajos','Pasa-Altos','Pasa-Banda','Rechaza-Banda','Realce (Unsharp)'};

    % Tamaño de referencia para el kernel
    N = 128;
    [u, v] = meshgrid(linspace(-0.5,0.5,N), linspace(-0.5,0.5,N));
    D = sqrt(u.^2 + v.^2);

    H2D = construirFiltro(D, fc1, fc2, n_ord, modo, forma);

    % Respuesta al impulso 2D (IFFT del filtro)
    h2D = real(ifft2(ifftshift(H2D)));
    h2D_shift = fftshift(h2D);   % centrar en origen

    % Perfiles 1D radiales
    fu_1d = linspace(-0.5, 0.5, N);
    H_1d  = H2D(round(N/2), :);    % fila central = perfil radial
    h_1d  = h2D_shift(round(N/2),:);

    figS = figure('Name','Respuesta al Impulso y Respuesta en Frecuencia',...
        'NumberTitle','off','Position',[120 80 1050 650],'Color',[1 1 1]);

    tipoStr = tipos{modo};
    formas  = {'Ideal','Gaussiano','Butterworth'};
    formaStr = formas{forma};

    % -- H(jω) 2D --
    subplot(2,3,1);
    imagesc(fu_1d, fu_1d, H2D); colormap(gca,jet); colorbar;
    xlabel('u (ciclos/px)'); ylabel('v (ciclos/px)');
    title(sprintf('H(j\\omega) 2D\n%s — %s', tipoStr, formaStr),'FontWeight','bold');
    axis xy;
    if ismember(modo,[1,2,5])
        annotation_fc(gca, fc1, 'fc1');
    else
        annotation_fc(gca, fc1, 'fc1'); annotation_fc(gca, fc2, 'fc2');
    end

    % -- H(jω) perfil 1D --
    subplot(2,3,2);
    plot(fu_1d, H_1d,'b','LineWidth',2); grid on;
    xlabel('Frecuencia (ciclos/px)','FontSize',9);
    ylabel('|H(j\omega)|','FontSize',9);
    title(sprintf('H(j\\omega) — Perfil radial 1D\n%s — %s', tipoStr, formaStr),'FontWeight','bold');
    xline(fc1,'r--','LineWidth',1.5,'Label',sprintf('fc1=%.3f',fc1));
    if ismember(modo,[3,4])
        xline(fc2,'g--','LineWidth',1.5,'Label',sprintf('fc2=%.3f',fc2));
    end
    yline(0.707,'k:','LineWidth',1,'Label','-3dB');
    ylim([-0.1 1.2]);

    % -- h(t) 2D --
    subplot(2,3,4);
    imagesc(h2D_shift); colormap(gca,gray); colorbar;
    title('h(t) — Respuesta al Impulso 2D','FontWeight','bold');
    xlabel('m (px)'); ylabel('n (px)');

    % -- h(t) perfil 1D --
    subplot(2,3,5);
    t_ax = linspace(-N/2, N/2-1, N);
    plot(t_ax, h_1d,'r','LineWidth',1.8); grid on;
    xlabel('m (píxeles)','FontSize',9);
    ylabel('h(t)','FontSize',9);
    title('h(t) — Perfil horizontal (respuesta al impulso 1D)','FontWeight','bold');
    xline(0,'k:','LineWidth',1,'Label','Origen');

    % -- Magnitud H en dB --
    subplot(2,3,3);
    plot(fu_1d, 20*log10(H_1d + 1e-6),'b','LineWidth',2); grid on;
    xlabel('Frecuencia (ciclos/px)');
    ylabel('|H(j\omega)| (dB)');
    title('H(j\omega) — Escala logarítmica (dB)','FontWeight','bold');
    xline(fc1,'r--','LineWidth',1.5,'Label',sprintf('fc1=%.3f',fc1));
    if ismember(modo,[3,4])
        xline(fc2,'g--','LineWidth',1.5,'Label',sprintf('fc2=%.3f',fc2));
    end
    yline(-3,'k:','Label','-3 dB');

    % -- Fase H --
    subplot(2,3,6);
    H_fase = angle(H2D(round(N/2),:));
    plot(fu_1d, H_fase,'m','LineWidth',1.5); grid on;
    xlabel('Frecuencia (ciclos/px)');
    ylabel('\angle H(j\omega) (rad)');
    title('\angle H(j\omega) — Respuesta en fase','FontWeight','bold');

    sgtitle(sprintf('Sistema: %s   |   Forma: %s   |   fc1=%.3f   fc2=%.3f   n=%d',...
        tipoStr, formaStr, fc1, fc2, n_ord),...
        'FontSize',11,'FontWeight','bold','Color',[0.1 0.25 0.55]);
end

