function actualizarLabel(slider, lbl, tipo)
    v = get(slider,'Value');
    switch tipo
        case 'fc1',  set(lbl,'String',sprintf('fc1 = %.3f', v));
        case 'fc2',  set(lbl,'String',sprintf('fc2 = %.3f', v));
        case 'ord',  set(lbl,'String',sprintf('n = %d', round(v)));
    end
end

