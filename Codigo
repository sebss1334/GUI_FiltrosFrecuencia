function guardarImagen(btn, ~)
    fig = ancestor(btn,'figure');
    data = guidata(fig);
    if isempty(data.result)
        errordlg('Primero procese una imagen.','Sin resultado');
        return;
    end
    [arch,ruta] = uiputfile('*.png','Guardar imagen de salida');
    if arch ~= 0
        imwrite(data.result, fullfile(ruta,arch));
        msgbox('Imagen guardada exitosamente.','Listo');
    end
end

% =========================================================================
% FUNCIONES MATEMÁTICAS DE SOPORTE
% =========================================================================

function H = construirFiltro(D, fc1, fc2, n_ord, modo, forma)
% Construye la máscara H(jω) 2D según modo y forma.
% D   : matriz de distancias radiales normalizadas [0..0.5]
% fc1 : frecuencia de corte inferior (ciclos/px)
% fc2 : frecuencia de corte superior (ciclos/px) — solo para banda
% n_ord: orden Butterworth
% modo : 1=LP, 2=HP, 3=BP, 4=BS, 5=Realce
% forma: 1=Ideal, 2=Gaussiano, 3=Butterworth

    % Filtro pasa-bajos base
    switch forma
        case 1  % Ideal
            Hlp = double(D <= fc1);
        case 2  % Gaussiano
            Hlp = exp(-(D.^2) / (2*fc1^2));
        case 3  % Butterworth
            Hlp = 1 ./ (1 + (D/fc1).^(2*n_ord));
    end

    % Modificar según tipo de filtro deseado
    switch modo
        case 1  % Pasa-Bajos
            H = Hlp;
        case 2  % Pasa-Altos
            H = 1 - Hlp;
        case 3  % Pasa-Banda: LP(fc2) - LP(fc1)
            switch forma
                case 1, Hlp2 = double(D <= fc2);
                case 2, Hlp2 = exp(-(D.^2)/(2*fc2^2));
                case 3, Hlp2 = 1./(1+(D/fc2).^(2*n_ord));
            end
            H = Hlp2 - Hlp;
            H(H < 0) = 0;
        case 4  % Rechaza-Banda
            switch forma
                case 1, Hlp2 = double(D <= fc2);
                case 2, Hlp2 = exp(-(D.^2)/(2*fc2^2));
                case 3, Hlp2 = 1./(1+(D/fc2).^(2*n_ord));
            end
            H = 1 - (Hlp2 - Hlp);
            H(H < 0) = 0;
        case 5  % Realce (Unsharp Masking): original + k*bordes
            Hhp = 1 - Hlp;
            H   = 1 + 1.5 * Hhp;   % ganancia de realce fija
    end
end

function mostrarEspectro(img_gray, ax, titulo, ~)
% Muestra el espectro de magnitud 2D centrado con ejes en ciclos/px.
    [rows,cols] = size(img_gray);
    X   = fftshift(fft2(img_gray));
    mag = log(1 + abs(X));

    fu = linspace(-0.5,0.5,cols);
    fv = linspace(-0.5,0.5,rows);

    axes(ax);
    imagesc(fu, fv, mag);
    colormap(ax, hot);
    axis(ax,'xy');
    xlabel(ax,'u (ciclos/px)','FontSize',7);
    ylabel(ax,'v (ciclos/px)','FontSize',7);
    title(ax, titulo,'FontSize',8);
    colorbar(ax);
end

function annotation_fc(ax, fc, lbl)
% Dibuja líneas de frecuencia de corte en un eje imagesc.
    hold(ax,'on');
    xline(ax, fc,'w--','LineWidth',1.2,'Label',sprintf('%s=%.3f',lbl,fc),'LabelColor','w');
    xline(ax,-fc,'w--','LineWidth',1.2);
    yline(ax, fc,'w--','LineWidth',1.2);
    yline(ax,-fc,'w--','LineWidth',1.2);
    hold(ax,'off');
end
